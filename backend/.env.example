# Sao chép thành `.env` và chỉnh giá trị.

DATABASE_URL=postgresql+psycopg2://voicepro:voicepro@127.0.0.1:5434/voicepro
REDIS_URL=redis://127.0.0.1:6380/0

# JWT / app
JWT_SECRET_KEY=dev-jwt-secret-change-me
ENVIRONMENT=development

# Stripe (Epic 6)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Danh sách Price ID được coi là gói trả phí (single source of truth)
STRIPE_PAID_PRICE_IDS=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_SUCCESS_URL=http://localhost:5173/?checkout=success
STRIPE_CANCEL_URL=http://localhost:5173/?checkout=cancel
