# Copy to `.env` và điền giá trị. Không commit `.env`.

DATABASE_URL=postgresql+psycopg2://voicepro:voicepro@localhost:5432/voicepro
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional — Epic 1.5
SENTRY_DSN=
ENVIRONMENT=development

# Landing — Plausible (public)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

